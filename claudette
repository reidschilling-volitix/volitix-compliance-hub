      const handleChangePassword = async (e) => {
         e.preventDefault();
         if (!oldPassword || !newPassword) return;
         if (oldPassword !== customUser.password) return notify("Current password is incorrect.", "error");
         try {
            await updateDoc(doc(db, 'artifacts', appId, 'public', 'data', 'saas_users', customUser.id), { password: newPassword });
            notify("Password changed successfully!", "success");
            setCustomUser({...customUser, password: newPassword}); setOldPassword(''); setNewPassword('');
         } catch(err) { notify("Error changing password", "error"); }
      };
      return (
        <div className="space-y-8 animate-fade-in min-w-0">
          <FormCard title="Command Settings" icon={Settings2} onSubmit={handleCompanySettingsSave} submitLabel="Update Settings">
            <div className="grid grid-cols-1 md:grid-cols-2 gap-8">
              <Input label="Organization Name" value={company.name} onChange={e => setCompany({...company, name: e.target.value})} required/>
              <Input label="FAA Exemption Number" value={company.exemption} onChange={e => setCompany({...company, exemption: e.target.value})} />
              <Input label="Chief Supervisor / Pilot" value={company.supervisor} onChange={e => setCompany({...company, supervisor: e.target.value})} required/>
              <Input label="Part 137 / 107 Cert Number" value={company.certNo} onChange={e => setCompany({...company, certNo: e.target.value})} />
              <Input label="Business Phone" value={company.phone || ''} onChange={e => setCompany({...company, phone: e.target.value})} />
              <Select label="Local Time Zone" value={company.timezone} onChange={e => setCompany({...company, timezone: parseInt(e.target.value)})}>
                 {TIME_ZONES.map(tz => <option className="bg-slate-900" key={tz.offset} value={tz.offset}>{tz.label}</option>)}
              </Select>
              <div className="md:col-span-2"><Input label="Business Address" value={company.address || ''} onChange={e => setCompany({...company, address: e.target.value})} /></div>
            </div>
          </FormCard>
          <FormCard title="Account Security" icon={Lock} onSubmit={handleChangePassword} submitLabel="Update Password">
            <div className="grid grid-cols-1 md:grid-cols-2 gap-8">
               <div className="space-y-2 min-w-0"><label className={tw.label}>Username</label><input className={`${tw.input} cursor-not-allowed opacity-50`} value={customUser?.username || ''} disabled /></div>
               <div className="space-y-4 md:col-span-2 lg:col-span-1">
                 <Input label="Current Password" type={showPassword ? "text" : "password"} placeholder="Verify current password..." value={oldPassword} onChange={e => setOldPassword(e.target.value)} required rightElement={<button type="button" onClick={() => setShowPassword(!showPassword)} className="text-slate-500 hover:text-slate-300 focus:outline-none">{showPassword ? <EyeOff size={16}/> : <Eye size={16}/>}</button>} />
                 <Input label="New Password" type={showPassword ? "text" : "password"} placeholder="Enter new password..." value={newPassword} onChange={e => setNewPassword(e.target.value)} required />
               </div>
            </div>
          </FormCard>
        </div>
      );
    };

    // ============================================================================
    // SCHEDULE TAB - SIDEBAR + MAP LAYOUT
    // ============================================================================

    const ScheduleTab = ({ workOrders, isEditing, state, setState, onCancel, onSubmit, customers, products, fleet, customUser, handleDrop, handleDropToBacklog, getStatusColor, deleteItem, notify, onLogMission }) => {
      const [selectedMapJob, setSelectedMapJob] = useState(null);
      const [inlineCustomer, setInlineCustomer] = useState(false);
      const [newCustData, setNewCustData] = useState(defaultCustomerState);
      const [inlineProduct, setInlineProduct] = useState(false);
      const [newProdData, setNewProdData] = useState(defaultProductState);
      const [sidebarFilter, setSidebarFilter] = useState('all');
      const kmlRef = useRef(null);

      const calculateEstimate = (acresStr, aircraftArr, kml, appRateStr) => {
         const acres = parseFloat(acresStr) || 0;
         if (!acres || !aircraftArr || aircraftArr.length === 0) return { min: state.estHoursMin, max: state.estHoursMax };
         let totalAcresPerHour = 0;
         aircraftArr.forEach(droneId => { const droneObj = fleet.find(f => f.id === droneId); let rate = droneObj?.sprayRate ? parseFloat(droneObj.sprayRate) : 30; totalAcresPerHour += rate; });
         if (totalAcresPerHour === 0) totalAcresPerHour = 30;
         const gpa = parseFloat(appRateStr) || 2; const gpaMultiplier = Math.max(0.5, 1 + ((gpa - 2) * 0.2));
         let baseHours = (acres / totalAcresPerHour) * gpaMultiplier; baseHours += 0.3; 
         let hazardMultiplier = 1.0;
         if (kml) { const kmlLower = kml.toLowerCase(); if (kmlLower.includes('power') || kmlLower.includes('line')) hazardMultiplier += 0.2; if (kmlLower.includes('tree') || kmlLower.includes('obstacle') || kmlLower.includes('house')) hazardMultiplier += 0.15; const coordMatches = (kml.match(/<coordinates>/g) || []).length; if (coordMatches > 2) hazardMultiplier += 0.15; else hazardMultiplier += 0.1; }
         const adjustedHours = baseHours * hazardMultiplier;
         return { min: Math.max(0.2, (adjustedHours * 0.9)).toFixed(1), max: Math.max(0.3, (adjustedHours * 1.25)).toFixed(1) };
      };

      const handleKml = (e) => {
        const file = e.target.files[0]; if (!file) return;
        const reader = new FileReader();
        reader.onload = (ev) => {
            const kmlStr = ev.target.result;
            const est = calculateEstimate(state.acres, state.selectedAircraft, kmlStr, state.appRate);
            setState(prev => ({ ...prev, kmlData: kmlStr, kmlFileName: file.name, estHoursMin: est.min, estHoursMax: est.max }));
        };
        reader.readAsText(file);
      };

      const scheduleStats = useMemo(() => {
         const now = new Date();
         const startOfWeek = new Date(now); startOfWeek.setDate(now.getDate() - now.getDay());
         const endOfWeek = new Date(startOfWeek); endOfWeek.setDate(startOfWeek.getDate() + 6);
         return {
            unscheduled: workOrders.filter(w => !w.isScheduled && w.status !== 'Scheduled' && w.status !== 'Completed').length,
            unscheduledJobs: workOrders.filter(w => !w.isScheduled && w.status !== 'Scheduled' && w.status !== 'Completed'),
            thisWeekCount: workOrders.filter(w => w.isScheduled && new Date(w.date) >= startOfWeek && new Date(w.date) <= endOfWeek).length,
            activeCount: workOrders.filter(w => w.status === 'Scheduled' || w.status === 'In Progress').length,
            schedAcres: workOrders.filter(w => w.status === 'Scheduled' || w.status === 'In Progress').reduce((a, w) => a + (parseFloat(w.acres)||0), 0),
            compAcres: workOrders.filter(w => w.status === 'Completed').reduce((a, w) => a + (parseFloat(w.acres)||0), 0)
         };
      }, [workOrders]);

      const filteredOrders = useMemo(() => {
        if (sidebarFilter === 'backlog') return workOrders.filter(w => !w.isScheduled && w.status !== 'Completed' && w.status !== 'Cancelled');
        if (sidebarFilter === 'scheduled') return workOrders.filter(w => w.isScheduled && w.status !== 'Completed');
        if (sidebarFilter === 'completed') return workOrders.filter(w => w.status === 'Completed');
        return workOrders.filter(w => w.status !== 'Cancelled');
      }, [workOrders, sidebarFilter]);

      const mappedJobs = useMemo(() => workOrders.filter(w => w.finalLat && w.finalLon), [workOrders]);

      if (isEditing) {
        return (
          <FormCard title={state.id ? "Edit Work Order" : "Create Work Order"} icon={CalendarDays} onSubmit={(e) => onSubmit(e, inlineCustomer ? newCustData : null, inlineProduct ? newProdData : null)} onCancel={onCancel} submitLabel={state.status === 'Completed' ? "Save & Log Mission" : "Save Schedule"}>
            <div className="grid grid-cols-1 md:grid-cols-2 gap-6 min-w-0">
              <Input label="Job Title" value={state.title} onChange={e => setState({...state, title: e.target.value})} required placeholder="e.g. Field 1 Spray"/>
              <div className="flex flex-col gap-2 min-w-0">
                 <Select label="Customer" value={inlineCustomer ? 'ADD_NEW' : state.customer} onChange={e => { if(e.target.value === 'ADD_NEW') setInlineCustomer(true); else { setInlineCustomer(false); setState({...state, customer: e.target.value}); } }} required>
                   <option className="bg-slate-900" value="">Select Customer...</option>
                   {customers.map(c => <option className="bg-slate-900" key={c.id} value={c.name}>{String(c.name)}</option>)}
                   <option className="bg-slate-800 text-[#9cd33b]" value="ADD_NEW">+ Create New Customer</option>
                 </Select>
                 {inlineCustomer && <InlineCustomerForm data={newCustData} setData={setNewCustData} onClose={() => setInlineCustomer(false)} />}
              </div>
              <Input type="date" label="Scheduled Date (Optional)" value={state.date} onChange={e => {
                  const newDate = e.target.value;
                  let newStatus = state.status;
                  if (newDate && (!newStatus || newStatus === 'Pending')) newStatus = 'Scheduled';
                  if (!newDate) newStatus = 'Pending';
                  setState({...state, date: newDate, status: newStatus, isScheduled: !!newDate});
              }} />
              <div className="space-y-2 lg:col-span-2 min-w-0">
                 <label className={tw.label}>Assign Aircraft (Auto-calculates ETA)</label>
                 <div className="flex flex-wrap gap-2">
                    {fleet.map((d, i) => { 
                       const droneId = d.id || `Unknown-${i}`; 
                       return (
                          <button key={i} type="button" onClick={() => { 
                             const cur = state.selectedAircraft || []; 
                             const next = cur.includes(droneId) ? cur.filter(a=>a!==droneId) : [...cur, droneId]; 
                             const est = calculateEstimate(state.acres, next, state.kmlData, state.appRate);
                             setState({...state, selectedAircraft: next, estHoursMin: est.min, estHoursMax: est.max}); 
                          }} className={`px-4 py-3 rounded-xl border text-[10px] font-black uppercase tracking-widest transition-all truncate max-w-full ${(state.selectedAircraft || []).includes(droneId) ? 'bg-[#9cd33b] text-[#020617] border-[#9cd33b] shadow-lg' : 'bg-slate-950 border-slate-800 text-slate-500 hover:border-[#9cd33b]/50'}`}>
                             {String(droneId)}
                          </button>
                       ); 
                    })}
                 </div>
              </div>
              <Input type="number" label="Acreage" value={state.acres} onChange={e => {
                  const val = e.target.value;
                  const est = calculateEstimate(val, state.selectedAircraft, state.kmlData, state.appRate);
                  setState({...state, acres: val, estHoursMin: est.min, estHoursMax: est.max});
              }} required/>
              <Input label="App Vol. (GPA)" type="number" step="any" value={state.appRate || ''} onChange={e => {
                  const val = e.target.value;
                  const est = calculateEstimate(state.acres, state.selectedAircraft, state.kmlData, val);
                  setState({...state, appRate: val, estHoursMin: est.min, estHoursMax: est.max});
              }} rightElement={<span className="text-[9px] text-slate-500 font-black">GPA</span>} />
              <div className="space-y-2 min-w-0">
                 <label className={tw.label}>Est. Time Range (Hrs)</label>
                 <div className="flex gap-2">
                   <input type="number" step="any" placeholder="Min" className={tw.input} value={state.estHoursMin} onChange={e => setState({...state, estHoursMin: e.target.value})}/>
                   <input type="number" step="any" placeholder="Max" className={tw.input} value={state.estHoursMax} onChange={e => setState({...state, estHoursMax: e.target.value})}/>
                 </div>
              </div>
              <div className="flex flex-col gap-2 min-w-0 md:col-span-2">
                 <Select label="Chemical / Product" value={inlineProduct ? 'ADD_NEW' : (state.chemical || '')} onChange={e => { if(e.target.value === 'ADD_NEW') setInlineProduct(true); else { setInlineProduct(false); setState({...state, chemical: e.target.value}); } }} required>
                    <option className="bg-slate-900" value="" disabled>Select Product...</option>
                    {products.map(p => <option className="bg-slate-900" key={p.id} value={p.name}>{String(p.name)}</option>)}
                    <option className="bg-slate-800 text-[#9cd33b]" value="ADD_NEW">+ Create New Product</option>
                 </Select>
                 {inlineProduct && <InlineProductForm data={newProdData} setData={setNewProdData} onClose={() => setInlineProduct(false)} />}
              </div>
            </div>
            <GeoAndKmlInput notify={notify} state={state} setState={setState} kmlRef={kmlRef} handleKml={handleKml} />
            <Select label="Job Status" value={state.status} onChange={e => setState({...state, status: e.target.value})}>
              <option className="bg-slate-900" value="Pending">Pending Dispatch</option>
              <option className="bg-slate-900" value="Scheduled">Scheduled</option>
              <option className="bg-slate-900" value="In Progress">In Progress</option>
              <option className="bg-slate-900" value="Paused">Paused (Weather Hold)</option>
              <option className="bg-slate-900" value="Completed">Completed</option>
              <option className="bg-slate-900" value="Cancelled">Cancelled</option>
            </Select>
          </FormCard>
        );
      }

      // ---- MAIN SCHEDULE VIEW: SIDEBAR LEFT + MAP RIGHT ----
      return (
        <div className="space-y-6 animate-fade-in min-w-0 h-full flex flex-col">
           <div className="flex flex-col md:flex-row md:items-start justify-between gap-4 min-w-0 shrink-0">
             <div className="min-w-0">
               <h2 className="text-3xl font-black uppercase tracking-tighter text-white flex items-center gap-3 truncate"><CalendarDays className="text-[#9cd33b] shrink-0"/> Operations</h2>
               <p className="text-xs text-slate-400 font-bold uppercase tracking-widest mt-2 truncate">Schedule & Map View</p>
             </div>
             <Button onClick={() => setState({...defaultWorkOrderState, isEditing: true})}><Plus size={16}/> New Order</Button>
           </div>

           <div className="shrink-0"><StatsRow stats={scheduleStats} /></div>

           {/* SIDEBAR + MAP LAYOUT */}
           <div className="flex flex-row gap-4 min-w-0 flex-1" style={{height: 'calc(100vh - 22rem)', minHeight: '500px'}}>
              {/* LEFT SIDEBAR - Work Orders */}
              <div className="w-80 bg-slate-900 border border-slate-800 rounded-[2rem] flex flex-col shadow-xl shrink-0 overflow-hidden">
                 <div className="p-4 border-b border-slate-800 bg-slate-900/50 min-w-0 shrink-0">
                    <h3 className="font-black uppercase tracking-widest text-slate-100 text-xs truncate mb-3">Work Orders</h3>
                    <div className="flex gap-1 flex-wrap">
                       {[{id:'all',label:'All'},{id:'backlog',label:'Backlog'},{id:'scheduled',label:'Scheduled'},{id:'completed',label:'Done'}].map(f => (
                          <button key={f.id} onClick={() => setSidebarFilter(f.id)} className={`px-3 py-1.5 rounded-lg text-[9px] font-black uppercase tracking-widest transition-all ${sidebarFilter === f.id ? 'bg-[#9cd33b] text-[#020617]' : 'bg-slate-950 text-slate-500 hover:text-slate-300 border border-slate-800'}`}>{f.label}</button>
                       ))}
                    </div>
                 </div>
                 <div className="flex-1 overflow-y-auto p-3 space-y-2 min-h-0">
                    {filteredOrders.length === 0 && <div className="flex flex-col items-center justify-center h-full text-slate-600 py-8"><Clock size={32} className="mb-4 opacity-20"/><p className="text-[10px] font-black uppercase tracking-widest text-center px-4">No orders found</p></div>}
                    {filteredOrders.map(job => (
                       <div key={job.id} onClick={() => { if (job.finalLat && job.finalLon) setSelectedMapJob(job); }} className={`p-4 rounded-2xl cursor-pointer transition-all border shadow-sm min-w-0 ${selectedMapJob?.id === job.id ? 'bg-slate-800 border-[#9cd33b] shadow-[0_0_15px_rgba(156,211,59,0.15)]' : 'bg-slate-950 border-slate-800 hover:border-slate-700'}`}>
                          <div className="flex justify-between items-start mb-2 gap-2 min-w-0">
                             <span className="text-[11px] font-black text-slate-200 uppercase truncate block flex-1">{String(job.title || job.customer)}</span>
                             <div className={`inline-flex items-center px-2 py-0.5 rounded-full text-[8px] font-black uppercase tracking-widest border shrink-0 ${getStatusColor(job.status)}`}>{job.status}</div>
                          </div>
                          <p className="text-[10px] text-slate-400 font-bold uppercase truncate">{String(job.customer)}</p>
                          <p className="text-[9px] text-slate-500 font-mono mt-1 truncate">{String(job.acres)} AC {job.appRate ? `| ${job.appRate} GPA` : ''} {job.date ? `| ${job.date}` : ''}</p>
                          {job.chemical && <p className="text-[9px] text-[#9cd33b] font-bold uppercase mt-1 truncate">{String(job.chemical)}</p>}
                          <div className="flex justify-end gap-2 mt-3 pt-2 border-t border-slate-800/50">
                             <button onClick={(e) => { e.stopPropagation(); onLogMission(job); }} title="Log Mission" className="text-[#9cd33b] hover:text-[#bce455] transition-colors p-1"><ClipboardCheck size={13}/></button>
                             <button onClick={(e) => { e.stopPropagation(); setState({...job, isEditing: true}); }} className="text-blue-500 hover:text-blue-400 transition-colors p-1"><Edit3 size={13}/></button>
                             <button onClick={(e) => { e.stopPropagation(); deleteItem('work_orders', job.id); }} className="text-red-500 hover:text-red-400 transition-colors p-1"><Trash2 size={13}/></button>
                          </div>
                       </div>
                    ))}
                 </div>
              </div>

              {/* RIGHT MAP AREA */}
              <div className="flex-1 bg-slate-950 border border-slate-800 shadow-xl rounded-[3rem] relative min-w-0 p-2 h-full overflow-hidden z-10 flex flex-col">
                 {selectedMapJob ? (
                    <React.Fragment>
                       <LeafletMap lat={selectedMapJob.finalLat} lon={selectedMapJob.finalLon} kmlData={selectedMapJob.kmlData} jobs={mappedJobs} selectedJob={selectedMapJob} />
                       <div className="absolute bottom-6 left-6 right-6 z-[100]">
                          <div className="bg-slate-900/95 backdrop-blur-md border border-slate-700 rounded-2xl p-4 flex flex-col md:flex-row md:items-center gap-3 shadow-2xl">
                             <div className="flex-1 min-w-0">
                                <p className="text-sm font-black text-white uppercase truncate">{selectedMapJob.title || selectedMapJob.customer}</p>
                                <p className="text-[10px] text-slate-400 font-mono mt-0.5 truncate">{selectedMapJob.finalLat?.toFixed(5)}, {selectedMapJob.finalLon?.toFixed(5)} | {selectedMapJob.acres} AC</p>
                             </div>
                             <div className="flex gap-2 shrink-0">
                                <Button variant="secondary" className="py-2 px-4 text-[9px]" onClick={() => setState({...selectedMapJob, isEditing: true})}><Edit3 size={12}/> Edit</Button>
                                <Button className="py-2 px-4 text-[9px]" onClick={() => onLogMission(selectedMapJob)}><ClipboardCheck size={12}/> Log</Button>
                             </div>
                          </div>
                       </div>
                    </React.Fragment>
                 ) : (
                    <LeafletMap jobs={mappedJobs} />
                 )}
              </div>
           </div>
        </div>
      );
    };

    // ============================================================================
    // DISPATCHER ORDERS TAB
    // ============================================================================

    const DispatcherOrdersTab = ({ workOrders, isEditing, state, setState, onCancel, onSubmit, customers, products, customUser, getStatusColor, deleteItem, notify }) => {
      const [inlineCustomer, setInlineCustomer] = useState(false);
      const [newCustData, setNewCustData] = useState(defaultCustomerState);
      const [inlineProduct, setInlineProduct] = useState(false);
      const [newProdData, setNewProdData] = useState(defaultProductState);
      const kmlRef = useRef(null);
      const handleKml = (e) => { const file = e.target.files[0]; if (!file) return; const reader = new FileReader(); reader.onload = (ev) => setState(prev => ({ ...prev, kmlData: ev.target.result, kmlFileName: file.name })); reader.readAsText(file); };

      if (isEditing) {
        return (
          <FormCard title={state.id ? "Edit Work Order" : "Send New Work Order"} icon={Send} onSubmit={(e) => onSubmit(e, inlineCustomer ? newCustData : null, inlineProduct ? newProdData : null)} onCancel={onCancel} submitLabel="Submit Order to Ops">
            <div className="grid grid-cols-1 md:grid-cols-2 gap-6 min-w-0">
              <Input label="Job Title" value={state.title} onChange={e => setState({...state, title: e.target.value})} required placeholder="e.g. Field 1 Spray"/>
              <div className="flex flex-col gap-2 min-w-0">
                 <Select label="Customer" value={inlineCustomer ? 'ADD_NEW' : state.customer} onChange={e => { if(e.target.value === 'ADD_NEW') setInlineCustomer(true); else { setInlineCustomer(false); setState({...state, customer: e.target.value}); } }} required>
                   <option className="bg-slate-900" value="">Select Customer...</option>
                   {customers.map(c => <option className="bg-slate-900" key={c.id} value={c.name}>{String(c.name)}</option>)}
                   <option className="bg-slate-800 text-[#9cd33b]" value="ADD_NEW">+ Create New Customer</option>
                 </Select>
                 {inlineCustomer && <InlineCustomerForm data={newCustData} setData={setNewCustData} onClose={() => setInlineCustomer(false)} />}
              </div>
              <Input type="number" label="Acreage" value={state.acres} onChange={e => setState({...state, acres: e.target.value})} required/>
              <Input label="App Vol. (GPA)" type="number" step="any" value={state.appRate || ''} onChange={e => setState({...state, appRate: e.target.value})} rightElement={<span className="text-[9px] text-slate-500 font-black">GPA</span>} />
              <div className="flex flex-col gap-2 min-w-0 md:col-span-2">
                 <Select label="Chemical / Product" value={inlineProduct ? 'ADD_NEW' : (state.chemical || '')} onChange={e => { if(e.target.value === 'ADD_NEW') setInlineProduct(true); else { setInlineProduct(false); setState({...state, chemical: e.target.value}); } }} required>
                    <option className="bg-slate-900" value="" disabled>Select Product...</option>
                    {products.map(p => <option className="bg-slate-900" key={p.id} value={p.name}>{String(p.name)}</option>)}
