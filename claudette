              newRouteData.push({ job, eta: etaString, temp: data.hourly.temperature_2m[etaHour], humidity: data.hourly.relative_humidity_2m[etaHour], windSpeed: data.hourly.wind_speed_10m[etaHour], windDir: dirs[dirIdx], transit: transitData });
            } else { newRouteData.push({ job, eta: etaString, transit: transitData, error: "Forecast unavailable" }); }
            const minHrs = parseFloat(job.estHoursMin)||1; const maxHrs = parseFloat(job.estHoursMax)||1.5;
            currentMinTime += (minHrs*3600000); currentMaxTime += (maxHrs*3600000);
