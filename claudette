                   <div className="flex-1 flex gap-2">
                      <button type="button" onClick={() => kmlRef.current?.click()} className={`${tw.input} flex-1 text-[10px] font-black uppercase text-center truncate ${isDragging ? 'ring-2 ring-[#9cd33b]' : ''}`}>{state.kmlFileName || 'Drop / Upload KML File'}</button>
