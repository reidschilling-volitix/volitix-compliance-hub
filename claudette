      const dayJobs = useMemo(() => workOrders.filter(w => w.date === targetDate && w.status === 'Scheduled' && w.finalLat), [workOrders, targetDate]);
      const [orderedJobs, setOrderedJobs] = useState([]);
      useEffect(() => { setOrderedJobs(dayJobs); setRouteData([]); }, [dayJobs]);
      const moveJob = (index, dir) => { const nj = [...orderedJobs]; if (dir === 'up' && index > 0) [nj[index], nj[index-1]] = [nj[index-1], nj[index]]; else if (dir === 'down' && index < nj.length - 1) [nj[index], nj[index+1]] = [nj[index+1], nj[index]]; setOrderedJobs(nj); setRouteData([]); };
      const updateJobHours = (id, field, value) => { setOrderedJobs(jobs => jobs.map(j => j.id === id ? { ...j, [field]: value } : j)); setRouteData([]); };
      const calculateRouteWeather = async () => {
        if (orderedJobs.length === 0) return notify("No mapped jobs scheduled for this date.", "error");
        setIsLoading(true); notify("Pinging weather satellites for route...", "info");
        try {
          const newRouteData = []; const startDt = new Date(); const [hours, minutes] = startTime.split(':'); startDt.setHours(parseInt(hours,10), parseInt(minutes,10), 0, 0);
          let currentMinTime = startDt.getTime(); let currentMaxTime = startDt.getTime();
          for (let i = 0; i < orderedJobs.length; i++) {
            const job = orderedJobs[i]; const lat = parseFloat(job.finalLat)||39.82; const lon = parseFloat(job.finalLon)||-98.57;
            let transitData = null;
            if (i > 0) { const pj = orderedJobs[i-1]; const dist = getDistanceMiles(parseFloat(pj.finalLat)||39.82, parseFloat(pj.finalLon)||-98.57, lat, lon); const th = (dist/45)+0.25; currentMinTime += (th*3600000); currentMaxTime += (th*3600000); transitData = { miles: dist.toFixed(1), driveMins: Math.round((dist/45)*60) }; }
            const avgDt = new Date((currentMinTime+currentMaxTime)/2); const etaHour = avgDt.getHours();
            const minEtaStr = new Date(currentMinTime).toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'}); const maxEtaStr = new Date(currentMaxTime).toLocaleTimeString([],{hour:'2-digit',minute:'2-digit'});
            const etaString = i === 0 ? minEtaStr : `${minEtaStr} - ${maxEtaStr}`;
            const res = await fetch(`https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lon}&start_date=${targetDate}&end_date=${targetDate}&hourly=temperature_2m,relative_humidity_2m,wind_speed_10m,wind_direction_10m&temperature_unit=fahrenheit&wind_speed_unit=mph&timezone=auto`);
            const data = await res.json();
            if (data.hourly && data.hourly.temperature_2m[etaHour] !== undefined) {
