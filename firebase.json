{
  "functions": {
    "source": "functions"
  },
  "hosting": {
    "site": "sprayops",
    "public": "saas-app/dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "predeploy": [
      "npm --prefix saas-app run build"
    ]
  },
  "firestore": {
    "rules": "firestore.rules"
  }
}
