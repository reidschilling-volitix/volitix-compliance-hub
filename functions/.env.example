# Stripe secret and price IDs used by Cloud Functions
# STRIPE_SECRET_KEY and STRIPE_WEBHOOK_SECRET are provided via Firebase Secret Manager
STRIPE_PRICE_BASE=price_xxx
STRIPE_PRICE_ADDON_DRONE=price_xxx

# Backward-compat fallback if you still use the old naming
STRIPE_PRICE_STARTER=price_xxx

# Must match appId used in saas-app/src/firebase.js
APP_ARTIFACT_ID=aviation-compliance-hub
